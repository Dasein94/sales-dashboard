# SFTP credentials for your web host.
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below in your .env file
#   3. Never commit .env to git — it contains your password
#      (it is already listed in .gitignore)

# Your server's hostname or IP address (from your hosting control panel)
SFTP_HOST=yourdomain.com

# Your SFTP username
SFTP_USER=your_sftp_username

# Your SFTP password
SFTP_PASS=your_sftp_password

# SFTP port — 22 is the standard; only change if your host specifies otherwise
SFTP_PORT=22

# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# The remote directory where your site files are served from.
# On Network Solutions: SFTP root is /, web root is htdocs (no leading slash)
# Add a subfolder if you want the dashboard at yourdomain.com/dashboard/
SFTP_REMOTE_DIR=htdocs
